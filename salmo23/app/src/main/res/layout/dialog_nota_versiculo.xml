<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#A07844"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvReferenciaNota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gênesis 2:4"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estas são as origens dos céus e da terra..."
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/btnCancelarNota"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="Cancelar"
            android:textColor="#9E9E9E"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/btnSalvarNota"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Salvar"
            android:textColor="#9E9E9E"
            android:textSize="16sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <EditText
            android:id="@+id/etNotaVersiculo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:gravity="top"
            android:hint="Registre seus pensamentos..."
            android:padding="12dp"
            android:textSize="16sp"
            android:textColor="#444444"
            android:inputType="textMultiLine" />
    </androidx.cardview.widget.CardView>

</LinearLayout>