<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/bg_stats_dashed"
    android:elevation="8dp"
    android:outlineProvider="background">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="4dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/imgNovenaIcon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_santo" />

        <LinearLayout
            android:id="@+id/rightContainer"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/favoriteButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Favoritar"
                android:padding="4dp"
                android:src="@drawable/ic_favorite_border" />

            <LinearLayout
                android:id="@+id/layoutProgresso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp">

                    <com.mikhaellopez.circularprogressbar.CircularProgressBar
                        android:id="@+id/progressCircular"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cpb_background_progressbar_color="#EEEEEE"
                        app:cpb_background_progressbar_width="2.5dp"
                        app:cpb_progressbar_color="@color/colorPrimary"
                        app:cpb_progressbar_width="2.5dp" />

                    <TextView
                        android:id="@+id/txtProgressoTexto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="0/9"
                        android:textColor="@color/colorPrimary"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieItemConcluido"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone"
                        app:lottie_fileName="concluido.json" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/textContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="2dp"
            android:layout_toStartOf="@id/rightContainer"
            android:layout_toEndOf="@id/imgNovenaIcon"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNomeNovenaLista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Novena de São Jorge"
                android:textColor="#333333"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtPadroeiroLista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:drawableStart="@drawable/ic_pray1"
                android:drawablePadding="3dp"
                android:gravity="center_vertical"
                android:text="São Jorge"
                android:textSize="10sp"

                android:maxLines="1"
                android:singleLine="true"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/txtCausaLista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Intenção: Pela saúde"
                android:textColor="#666666"
                android:textSize="13sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtDiaFestaLista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:drawableStart="@drawable/ic_calendar1"
                android:drawableTint="#424242"
                android:drawablePadding="3dp"
                android:gravity="center_vertical"
                android:text="Festa: 23 de Abril"
                android:textColor="#888888"
                android:textSize="10sp" />

        </LinearLayout>
    </RelativeLayout>
</FrameLayout>