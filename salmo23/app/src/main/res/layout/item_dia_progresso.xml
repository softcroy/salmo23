<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <View
            android:id="@+id/lineTop"
            android:layout_width="20dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/line_dashed" />

        <ImageView
            android:id="@+id/imgIndicator"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_circle_outline" />

        <View
            android:id="@+id/lineBottom"
            android:layout_width="20dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/line_dashed" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardDia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="2dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/imgAction"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtDiaTitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dia 1"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtSubtitulo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Oração Inicial"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtDataConclusao"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 de maio às 20:00"
                    android:textSize="11sp"
                    android:textColor="#EEEEEE"
                    android:layout_marginTop="2dp"
                    android:visibility="gone" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imgAction"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_lock" />

        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>