<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/viewSideColor"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/colorPrimary"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvFavReferencia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gênesis 2:2"
                    android:textColor="#212121"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnEditFav"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_mode_edit"
                    android:visibility="gone"
                    app:tint="#BDBDBD" />

                <View
                    android:id="@+id/viewCircleColor"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/circle_shape"
                    android:visibility="gone" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvFavTextoVersiculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="E havendo Deus acabado..."
                android:textColor="#757575"
                android:fontFamily="@font/font"
                android:textSize="20sp" />

            <FrameLayout
                android:id="@+id/layoutNotaExtra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#F5F5F5"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvFavNotaConteudo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Minha anotação aqui"
                    android:textColor="#212121"
                    android:textSize="14sp" />
            </FrameLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/tvFavData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mar. 04, 2026"
                    android:textColor="#BDBDBD"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/btnDeleteFav"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/trash"
                     />
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>