<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutFav"
        android:layout_width="match_parent"
        android:layout_height="40sp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_tab_favoritos"
        app:tabIndicatorHeight="0dp"
        app:tabRippleColor="@null"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="@color/colorPrimary"
        app:tabBackground="@drawable/tab_selector_favoritos"
        app:tabMode="fixed"
        app:tabTextAppearance="@style/CustomTabTextStyle"/>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerFav"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/tela_banner"
        android:layout_below="@id/tabLayoutFav"/>
    <LinearLayout
        android:id="@+id/tela_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true">

        <FrameLayout
            android:id="@+id/ad_view_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true" />
    </LinearLayout>

</RelativeLayout>