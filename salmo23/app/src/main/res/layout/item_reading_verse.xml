<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tvNumVersiculo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/font"
        android:text="1"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTextoVersiculo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/tvNumVersiculo"
        android:lineSpacingExtra="5dp"
        android:paddingEnd="40dp"
        android:fontFamily="@font/font"
        android:textStyle="bold"
        android:text="No princípio criou Deus o céu e a terra."
        android:textColor="#737373"
        android:textSize="22sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:layout_marginTop="10dp">

        <ImageView
            android:id="@+id/imgNotaIcon"
            android:layout_width="25sp"
            android:layout_height="25sp"
            android:layout_marginEnd="6dp"
            android:src="@drawable/note_favorite"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/imgMarcadorIcon"
            android:layout_width="25sp"
            android:layout_height="25sp"
            android:src="@drawable/mark_favorite"
            android:visibility="gone" />

    </LinearLayout>

</RelativeLayout>