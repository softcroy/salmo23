<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:card_view="http://schemas.android.com/tools">

    <androidx.cardview.widget.CardView
        android:layout_margin="5sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        android:dividerHeight="19.0px"
        android:clipToPadding="false"
        android:clipChildren="false"
        card_view:cardMaxElevation="7dp"
        card_view:cardCornerRadius="5sp"
        android:divider="@android:color/transparent"
        app:cardPreventCornerOverlap="false"
        android:id="@+id/cardview1"
        card_view:cardElevation="10sp">


        <LinearLayout
            android:layout_width="0sp"
            android:layout_height="0sp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/identificador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginLeft="5sp"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:fontFamily="@font/google"
                android:singleLine="true"
                android:textColor="@color/grey" />

            <TextView
                android:id="@+id/oracao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:fontFamily="@font/google"
                android:gravity="left|center_vertical"
                android:singleLine="true"
                android:text="1000"
                android:textColor="@color/grey" />

            <TextView
                android:id="@+id/id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:fontFamily="@font/font"
                android:gravity="left|center_vertical"
                android:singleLine="true"
                android:text="Oração de nossa senhora"
                android:textColor="@color/grey"
                android:textSize="20dp" />

            <TextView
                android:id="@+id/data"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:fontFamily="@font/google"
                android:gravity="left|center_vertical"
                android:singleLine="true"
                android:text="1000"
                android:textColor="@color/grey" />

            <TextView
                android:id="@+id/image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:fontFamily="@font/google"
                android:gravity="left|center_vertical"
                android:singleLine="true"
                android:text="1000"
                android:textColor="@color/grey" />

            <TextView
                android:id="@+id/icone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:fontFamily="@font/google"
                android:gravity="left|center_vertical"
                android:singleLine="true"
                android:text="1000"
                android:textColor="@color/grey" />

            <TextView
                android:id="@+id/sond"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:ellipsize="marquee"
                android:fontFamily="@font/google"
                android:gravity="left|center_vertical"
                android:singleLine="true"
                android:text="1000"
                android:textColor="@color/grey" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            >

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/imagefeed"
                        android:layout_width="70sp"
                        android:layout_height="70sp"
                        android:layout_gravity="left"
                        android:padding="5sp"
                        android:src="@mipmap/ic_launcher" />

                    <TextView
                        android:id="@+id/nome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="marquee"
                        android:fontFamily="@font/font"
                        android:singleLine="true"
                        android:textColor="#737373"
                        android:textSize="19sp"
                        android:layout_gravity="center"/>

                </LinearLayout>

            </RelativeLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>