<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/headerConcluidas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minhas Graças"
            android:textColor="@color/colorPrimary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Novenas finalizadas e intenções alcançadas"
            android:textColor="#757575"
            android:textSize="13sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerConcluidas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerConcluidas"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="80dp" />

    <RelativeLayout
        android:id="@+id/layoutSemNovena"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:padding="20dp"
        android:visibility="gone">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieEmpty"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_centerInParent="true"
            app:lottie_speed="1.8"
            app:lottie_autoPlay="false"
            app:lottie_fileName="sem_novena.json"
            app:lottie_loop="false" />

        <TextView
            android:id="@+id/txtAvisoVazio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Sua caminhada de fé está apenas começando.\nSuas novenas finalizadas aparecerão aqui!"
            android:textColor="#8D6E63"
            android:textSize="15sp"
            android:textStyle="italic"
            android:visibility="invisible" />

    </RelativeLayout>

</RelativeLayout>