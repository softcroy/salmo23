<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    android:background="@android:color/white"
    android:padding="24dp">

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieFelicitacao"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_centerHorizontal="true"
        app:lottie_autoPlay="true"
        app:lottie_repeatMode="reverse"
        app:lottie_fileName="sem_novena.json"
        app:lottie_loop="true"
        app:lottie_speed="1.8" />

    <TextView
        android:id="@+id/txtTituloFelicitacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/lottieFelicitacao"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:fontFamily="serif"
        android:gravity="center"
        android:text="Novena Concluída!"
        android:textColor="@color/colorPrimary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtDescricaoFelicitacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtTituloFelicitacao"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:fontFamily="serif"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:text="Que Deus, em sua infinita misericórdia, ouça as suas preces e realize a intenção desta novena. Parabéns pela sua caminhada de fé!"
        android:textColor="#4E342E"
        android:textSize="16sp"
        android:textStyle="italic" />

    <Button
        android:id="@+id/btnFecharFelicitacao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtDescricaoFelicitacao"
        android:layout_marginTop="24dp"
        android:backgroundTint="@color/colorPrimary"
        android:text="AMÉM"
        android:textColor="@android:color/white"
        android:textStyle="bold" />

</RelativeLayout>