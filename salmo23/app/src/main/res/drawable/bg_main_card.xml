<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- sombra suave -->
    <item
        android:top="3dp">

        <shape android:shape="rectangle">

            <solid android:color="#12000000" />

            <corners
                android:topLeftRadius="38dp"
                android:topRightRadius="38dp" />

        </shape>
    </item>

    <!-- card principal -->
    <item>

        <shape android:shape="rectangle">

            <!-- gradiente clean -->
            <gradient
                android:angle="270"
                android:startColor="#FFFFFF"
                android:centerColor="#FCFEFF"
                android:endColor="#F3F9FF" />

            <!-- bordas -->
            <corners
                android:topLeftRadius="38dp"
                android:topRightRadius="38dp" />

            <!-- borda glass -->
            <stroke
                android:width="1dp"
                android:color="#DDEFFD" />

            <!-- padding -->
            <padding
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp" />

        </shape>
    </item>

    <!-- brilho superior -->
    <item
        android:gravity="top">

        <shape android:shape="rectangle">

            <size android:height="5dp" />

            <gradient
                android:angle="0"
                android:startColor="@android:color/transparent"
                android:centerColor="#CCFFFFFF"
                android:endColor="@android:color/transparent" />

            <corners
                android:topLeftRadius="38dp"
                android:topRightRadius="38dp" />

        </shape>
    </item>

</layer-list>