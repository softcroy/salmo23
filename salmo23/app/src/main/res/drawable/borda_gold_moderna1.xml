<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

  <!-- Fundo -->
  <solid android:color="#FFFFFF" />

  <!-- Borda dourada -->
  <stroke
      android:width="1.5dp"
      android:color="#DDB04D" />

  <!-- Cantos -->
  <corners android:radius="24dp" />

  <!-- Espaçamento interno -->
  <padding
      android:left="18dp"
      android:top="18dp"
      android:right="18dp"
      android:bottom="18dp" />

</shape>