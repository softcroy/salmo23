<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- sombra -->
    <item
        android:top="3dp">

        <shape android:shape="rectangle">

            <solid android:color="#10000000"/>

            <corners android:radius="28dp"/>

        </shape>
    </item>

    <!-- card -->
    <item>

        <shape android:shape="rectangle">

            <!-- gradiente -->
            <gradient
                android:angle="270"
                android:startColor="#FFFFFF"
                android:centerColor="#F9FCFF"
                android:endColor="#EEF7FF"/>

            <!-- bordas -->
            <corners android:radius="28dp"/>

            <!-- borda -->
            <stroke
                android:width="1dp"
                android:color="#DDEEFF"/>

            <!-- padding -->
            <padding
                android:left="8dp"
                android:top="8dp"
                android:right="8dp"
                android:bottom="8dp"/>

        </shape>
    </item>

    <!-- brilho topo -->
    <item
        android:gravity="top">

        <shape android:shape="rectangle">

            <size android:height="4dp"/>

            <gradient
                android:angle="0"
                android:startColor="#40FFFFFF"
                android:centerColor="#AAFFFFFF"
                android:endColor="#40FFFFFF"/>

            <corners android:radius="28dp"/>

        </shape>
    </item>

</layer-list>