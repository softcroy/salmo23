<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- sombra -->
    <item
        android:top="2dp">

        <shape android:shape="oval">

            <solid android:color="#12000000"/>

        </shape>
    </item>

    <!-- círculo principal -->
    <item>

        <shape android:shape="oval">

            <gradient
                android:angle="270"
                android:startColor="#FFFFFF"
                android:endColor="#F2F9FF"/>

            <stroke
                android:width="1dp"
                android:color="#D9ECFF"/>

        </shape>
    </item>

    <!-- glow interno -->
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">

        <shape android:shape="oval">

            <gradient
                android:type="radial"
                android:gradientRadius="40dp"
                android:centerColor="#1864CFFB"
                android:endColor="#0064CFFB"/>

        </shape>
    </item>

</layer-list>