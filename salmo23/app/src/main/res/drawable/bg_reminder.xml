<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- fundo -->
    <gradient
        android:angle="0"
        android:startColor="#EAF7FF"
        android:endColor="#DDF1FF" />

    <!-- bordas arredondadas -->
    <corners android:radius="18dp" />

    <!-- borda suave -->
    <stroke
        android:width="1dp"
        android:color="#CFE9FF" />

    <!-- espaço interno -->
    <padding
        android:left="10dp"
        android:top="6dp"
        android:right="10dp"
        android:bottom="6dp" />

</shape>