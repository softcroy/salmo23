<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- sombra -->
    <item
        android:top="2dp">

        <shape android:shape="oval">

            <solid android:color="#12000000"/>

        </shape>
    </item>

    <!-- botão -->
    <item>

        <shape android:shape="oval">

            <gradient
                android:angle="270"
                android:startColor="#FFFFFF"
                android:endColor="#EEF8FF"/>

            <stroke
                android:width="1dp"
                android:color="#D8ECFF"/>

        </shape>
    </item>

    <!-- brilho -->
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">

        <shape android:shape="oval">

            <gradient
                android:type="radial"
                android:gradientRadius="22dp"
                android:centerColor="#2064CFFB"
                android:endColor="#0064CFFB"/>

        </shape>
    </item>

</layer-list>